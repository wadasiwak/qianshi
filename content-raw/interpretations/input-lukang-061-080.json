[
 {
  "id": 61,
  "level": "上",
  "poem": [
   "熟讀黃庭愛學仙",
   "果然遇得好姻緣",
   "秋風吹墮月中桂",
   "看汝飛昇上九天"
  ],
  "official": {
   "功名": "秋風報喜，必有好音",
   "行人": "天緣湊巧，遇在目前",
   "婚姻": "姻緣和合，且得佳麗",
   "官司": "大合官情，所向無屈",
   "丁口": "財喜臨門，家人有慶",
   "生意": "財氣滿足，立秋大利",
   "疾病": "占遇升騰，於病不利",
   "出行": "順風揚帆，大有際遇",
   "失物": "追尋可遇，失物當還",
   "田畜": "孳生蕃茂，秋來得利"
  }
 },
 {
  "id": 62,
  "level": "下下",
  "poem": [
   "小智而今莫漫施",
   "損人自損豈非痴",
   "上天報應原無爽",
   "風雨雷霆詎有私"
  ],
  "official": {
   "功名": "營私自誤，莫問前程",
   "行人": "天涯杳杳，音信沉沉",
   "婚姻": "鑽謀不成，心勞日拙",
   "官司": "私不勝理，曲難作直",
   "丁口": "丁眷啾唧，旦夕呻吟",
   "生意": "戕伐之後，難望敷榮",
   "疾病": "疾已沉疴，醫藥無功",
   "出行": "此去無緣，恐有阻礙",
   "失物": "從此小心，免再失脫",
   "田畜": "田園消耗，牧產蕭疏"
  }
 },
 {
  "id": 63,
  "level": "中",
  "poem": [
   "我今與汝說分明",
   "此去崎嶇路不平",
   "救得難中人一個",
   "即憑陰騭免災生"
  ],
  "official": {
   "功名": "前程艱難，積德為先",
   "行人": "水遠山高，音信難通",
   "婚姻": "事多阻隔，且自隨緣",
   "官司": "責己恕人，可保平安",
   "丁口": "家人口舌，時有災星",
   "生意": "不思獨善，自得平安",
   "疾病": "病勢多險，虔誠祈求",
   "出行": "道失平安，步履艱險",
   "失物": "小心防閑，可免失脫",
   "田畜": "命途不良，心多煩惱"
  }
 },
 {
  "id": 64,
  "level": "中下",
  "poem": [
   "爭名奪利竟何如",
   "鏡裏看花總是虛",
   "處世惟存忠厚好",
   "閉門安樂享豐餘"
  ],
  "official": {
   "功名": "富貴在天，只宜守舊",
   "行人": "行人阻滯，消息非真",
   "婚姻": "莫羨虛花，且宜守舊",
   "官司": "退讓平安，進則有難",
   "丁口": "雖然多事，幸得平安",
   "生意": "勞心費力，名利皆虛",
   "疾病": "尚未痊安，且宜靜養",
   "出行": "徒然跋涉，且賦歸來",
   "失物": "運犯破耗，須防失財",
   "田畜": "眼前看好，終屬空虛"
  }
 },
 {
  "id": 65,
  "level": "中",
  "poem": [
   "褻瀆三光造孽多",
   "汝今求禱歎無因",
   "欲逃此日風波險",
   "改過虔誠奉斗真"
  ],
  "official": {
   "功名": "何須奢望，急於自省",
   "行人": "雲海茫茫，無由相見",
   "婚姻": "天緣不湊，人力空勞",
   "官司": "急宜自保，爭則有悔",
   "丁口": "家眷啾唧，作福保安",
   "生意": "莫求利息，且保平安",
   "疾病": "命途危險，虔誠祈求",
   "出行": "閉門守舊，不必遠行",
   "失物": "運蹇時來，謹防失脫",
   "田畜": "消耗日多，生息不旺"
  }
 },
 {
  "id": 66,
  "level": "下下",
  "poem": [
   "陰謀詭計日益精",
   "神目如電雷霆驚",
   "人有千算天一算",
   "自作自受最分明"
  ],
  "official": {
   "功名": "痴心妄想，一事無成",
   "行人": "時運不通，事事阻隔",
   "婚姻": "枉費心機，事難成就",
   "官司": "天網恢恢，無從逃避",
   "丁口": "自作不善，必有災殃",
   "生意": "命窮財盡，愈算愈拙",
   "疾病": "自絕於天，祈求無益",
   "出行": "風波不測，蹈險徒勞",
   "失物": "財聚人怨，破損該然",
   "田畜": "時運不通，事事相左"
  }
 },
 {
  "id": 67,
  "level": "中",
  "poem": [
   "暑月途中熱不勝",
   "忽沾雨露頓心清",
   "勸君更俟涼風動",
   "管取飄飄兩腋輕"
  ],
  "official": {
   "功名": "勸汝安心，秋風報喜",
   "行人": "音信已通，萍踪可合",
   "婚姻": "清淡為佳，趨炎則否",
   "官司": "不須著急，可保平安",
   "丁口": "夏防小災，秋季順利",
   "生意": "夏季平平，秋來大利",
   "疾病": "用心保養，自能復元",
   "出行": "春夏未佳，秋冬迪吉",
   "失物": "目前雖失，終久返還",
   "田畜": "秋前未佳，秋後順利"
  }
 },
 {
  "id": 68,
  "level": "中中",
  "poem": [
   "忽見蛟龍起海中",
   "雲騰致雨浪兼風",
   "善人遇此心安定",
   "庸俗相逢膽戰忡"
  ],
  "official": {
   "功名": "先難後進，端在修為",
   "行人": "路多驚險，音信遲滯",
   "婚姻": "事不安穩，切莫妄求",
   "官司": "自問無漸，方得安穩",
   "丁口": "雖有啾唧，可無大害",
   "生意": "守己待時，可免疑慮",
   "疾病": "病勢危險，作善求安",
   "出行": "此去未利，恐有驚險",
   "失物": "從此小心，自無差失",
   "田畜": "現時不利，須防小災"
  }
 },
 {
  "id": 69,
  "level": "上",
  "poem": [
   "兒童竹馬喜相迎",
   "共說神君吏治明",
   "從此五風兼十雨",
   "家家戶戶慶豐登"
  ],
  "official": {
   "功名": "功成名就，事事如意",
   "行人": "童子迎門，行人即至",
   "婚姻": "姻緣和合，且喜多男",
   "官司": "貴人有緣，諸事順利",
   "丁口": "長幼咸寧，家門有慶",
   "生意": "財源廣進，利路亨通",
   "疾病": "吉人天相，解厄迎祥",
   "出行": "順風揚帆，無往不利",
   "失物": "陽長陰消，失而復得",
   "田畜": "田園茂盛，六畜興旺"
  }
 },
 {
  "id": 70,
  "level": "上",
  "poem": [
   "許汝三天有順風",
   "開船平穩任西東",
   "財源輻輳何須說",
   "一路榮華命運通"
  ],
  "official": {
   "功名": "功高名顯，一路榮華",
   "行人": "三天以內，必有好音",
   "婚姻": "天相吉人，和諧順意",
   "官司": "一往順利，諸事稱心",
   "丁口": "千祥雲集，百福會合",
   "生意": "財運亨通，萬事如意",
   "疾病": "福星拱照，可保平安",
   "出行": "一路平安，四方順適",
   "失物": "雖然失脫，去而復歸",
   "田畜": "五穀豐登，牧畜咸亨"
  }
 },
 {
  "id": 71,
  "level": "中",
  "poem": [
   "今年坐賈勝行商",
   "莫向江頭趁野航",
   "待得陽生冬至後",
   "出門事事見榮昌"
  ],
  "official": {
   "功名": "少年遲遲，晚景榮華",
   "行人": "音信延滯，先花後果",
   "婚姻": "正娶則吉，年底終成",
   "官司": "不須急性，到尾完結",
   "丁口": "平平過去，福自歸來",
   "生意": "財氣平平，冬至大利",
   "疾病": "一陽來復，方可全癒",
   "出行": "目前未利，冬後方佳",
   "失物": "不須尋覓，暗去明來",
   "田畜": "春夏平平，冬勝於秋"
  }
 },
 {
  "id": 72,
  "level": "下下",
  "poem": [
   "貧窮疾病倍傷神",
   "失脫官非聚一身",
   "求著此籤無一可",
   "閉門靜守渡秋春"
  ],
  "official": {
   "功名": "不須妄求，百事難成",
   "行人": "天涯杳杳，音信茫茫",
   "婚姻": "命犯孤鸞，休生妄想",
   "官司": "命運不通，動輙得咎",
   "丁口": "孤苦伶仃，門衰戶落",
   "生意": "勞心費力，總屬空虛",
   "疾病": "時衰運退，凶多吉少",
   "出行": "所向不利，不如閉門",
   "失物": "窮愁失脫，雪上加霜",
   "田畜": "田園荒廢，雞犬不寧"
  }
 },
 {
  "id": 73,
  "level": "中",
  "poem": [
   "故人寄我一封書",
   "約去他鄉共販絲",
   "若遇龍潭須謹慎",
   "平安全仗佛扶持"
  ],
  "official": {
   "功名": "祿運未通，須當守己",
   "行人": "書信已通，相見不遠",
   "婚姻": "姻緣遠覓，未利辰年",
   "官司": "風波不測，終得平穩",
   "丁口": "存心行善，保佑平安",
   "生意": "財氣未足，須當靜守",
   "疾病": "得過辰日，方保平安",
   "出行": "前途謹慎，恐驚不穩",
   "失物": "牧種未到，財氣平平",
   "田畜": "牧種未到，財氣平平"
  }
 },
 {
  "id": 74,
  "level": "上",
  "poem": [
   "與子當年有宿因",
   "同舟共濟勝周親",
   "若能更把真心托",
   "添喜添財孰比倫"
  ],
  "official": {
   "功名": "得遇知音，功成名就",
   "行人": "同心會合，千里相逢",
   "婚姻": "因親結親，財喜自旺",
   "官司": "貴人相扶，官司得勝",
   "丁口": "六親相和，添丁進財",
   "生意": "用人勿疑，財源自足",
   "疾病": "貴人出現，漸漸安好",
   "出行": "同伴得人，出門有益",
   "失物": "同居和好，失物可尋",
   "田畜": "利息頻添，更勝往年"
  }
 },
 {
  "id": 75,
  "level": "中",
  "poem": [
   "萬里長空一雁飛",
   "欲求同侶悵無依",
   "勸君且就蘆洲宿",
   "等待秋風振羽儀"
  ],
  "official": {
   "功名": "眼前未到，靜守待時",
   "行人": "故人天遠，且待秋期",
   "婚姻": "今年未利，且待明春",
   "官司": "該行則行，可止則止",
   "丁口": "家口未寧，有小啾唧",
   "生意": "財運未通，安心待時",
   "疾病": "認真保養，秋涼自痊",
   "出行": "守分守己，不可漫行",
   "失物": "運當損失，應破小財",
   "田畜": "田畜未旺，收成小利"
  }
 },
 {
  "id": 76,
  "level": "上中",
  "poem": [
   "萬頃波濤一葉舟",
   "安如磐石自夷猶",
   "吉人自有神明佑",
   "何必臨危事禱求"
  ],
  "official": {
   "功名": "福祿天成，全不費力",
   "行人": "遠人在途，相見不遠",
   "婚姻": "遠娶更宜，且得佳婦",
   "官司": "神力扶持，安穩無事",
   "丁口": "家門順利，人口平安",
   "生意": "隨意經營，財源興旺",
   "疾病": "吉人天相，不須介懷",
   "出行": "順風揚帆，諸事順利",
   "失物": "故物無恙，不求自歸",
   "田畜": "牧畜興旺，田財茂盛"
  }
 },
 {
  "id": 77,
  "level": "中",
  "poem": [
   "欲知此去真消息",
   "說汝聽時膽莫寒",
   "過得雪山千萬疊",
   "別開生面與君看"
  ],
  "official": {
   "功名": "無苦不成，先難後易",
   "行人": "欲尋消息，冬盡交春",
   "婚姻": "眼前未到，到底還佳",
   "官司": "事多不測，後可無妨",
   "丁口": "家有疾危，危而得安",
   "生意": "否極泰來，方得如意",
   "疾病": "病勢危險，終保平安",
   "出行": "跋涉險阻，苦盡甘來",
   "失物": "運多破財，小心謹慎",
   "田畜": "今歲未佳，過冬乃佳"
  }
 },
 {
  "id": 78,
  "level": "上",
  "poem": [
   "龍宮貝闕最莊嚴",
   "君去行商趁一帆",
   "財積如山人共羨",
   "到家正值燕呢喃"
  ],
  "official": {
   "功名": "前程遠大，衣錦榮歸",
   "行人": "行人大利，春來可到",
   "婚姻": "主得妻才，兼繁子嗣",
   "官司": "貴人相扶，諸事順利",
   "丁口": "門戶清吉，更喜添丁",
   "生意": "十分財氣，滿載而歸",
   "疾病": "祈禱求安，春來自癒",
   "出行": "到處順利，財氣充盈",
   "失物": "去而復來，失可再得",
   "田畜": "田宅興旺，六畜繁殖"
  }
 },
 {
  "id": 79,
  "level": "上",
  "poem": [
   "紫誥黃封耀古今",
   "祥雲擁護使星臨",
   "太平景象神人悦",
   "海若咸懷效順心"
  ],
  "official": {
   "功名": "福祿壽全，功高名顯",
   "行人": "喜信頻至，不日來臨",
   "婚姻": "子貴夫榮，百年和合",
   "官司": "貴人相扶，事事順遂",
   "丁口": "竹林清吉，日報平安",
   "生意": "財氣興旺，滿路異香",
   "疾病": "神靈庇佑，身體康寧",
   "出行": "吉星拱照，行必有利",
   "失物": "不必追求，物當自出",
   "田畜": "種竹養魚，利息加倍"
  }
 },
 {
  "id": 80,
  "level": "下下",
  "poem": [
   "前生逋欠我深知",
   "此日相償數適宜",
   "莫便生嗔兼悔恨",
   "塞翁失馬未為奇"
  ],
  "official": {
   "功名": "枉費心機，一無所就",
   "行人": "音信虛無，孤踪寂寞",
   "婚姻": "若問姻緣，有終則吉",
   "官司": "命運乖違，諸事顛倒",
   "丁口": "孤苦伶仃，窮愁潦倒",
   "生意": "欲圖得利，反折其本",
   "疾病": "自作之孽，悔恨已遲",
   "出行": "所向不利，漂泊無依",
   "失物": "前生所欠，今世償還",
   "田畜": "如釜養魚，如湯潑雪"
  }
 }
]