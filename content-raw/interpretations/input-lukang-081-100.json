[
 {
  "id": 81,
  "level": "中下",
  "poem": [
   "季子歸去意氣驕",
   "家人匐伏畏雄豪",
   "豈知富貴榮華事",
   "壹似朝潮與暮潮"
  ],
  "official": {
   "功名": "富貴不常，香消燈燼",
   "行人": "音信將至，非朝即暮",
   "婚姻": "勿論眼前，須防反覆",
   "官司": "官斷無常，事多反覆",
   "丁口": "勞瘁非常，眾人啾唧",
   "生意": "財氣雖有，東得西失",
   "疾病": "精神不固，癒亦難久",
   "出行": "朝秦暮楚，去留不定",
   "失物": "有聚必散，數所當然",
   "田畜": "目前雖旺，難保常榮"
  }
 },
 {
  "id": 82,
  "level": "中",
  "poem": [
   "鴻雁來時汝運通",
   "吳頭越尾好從容",
   "更看明月圓如鏡",
   "遇得神仙便御風"
  ],
  "official": {
   "功名": "桂月空明，秋香得意",
   "行人": "天邊鴻雁，相會有期",
   "婚姻": "急難成就，緩得團圓",
   "官司": "貴人有緣，自能順遂",
   "丁口": "合門順利，秋冬更吉",
   "生意": "春夏未利，秋冬甚佳",
   "疾病": "從容保養，秋來必痊",
   "出行": "若到蘇杭，諸事順利",
   "失物": "近水尋覓，月望可逢",
   "田畜": "田財有成，秋收富足"
  }
 },
 {
  "id": 83,
  "level": "上",
  "poem": [
   "萬里橋頭送客行",
   "壹場辛苦不須論",
   "憑將三寸蘇張舌",
   "唾手功成獨讓君"
  ],
  "official": {
   "功名": "吃盡辛苦，方得成名",
   "行人": "行人得意，消息可通",
   "婚姻": "先難後易，全仗良媒",
   "官司": "雖逢勁敵，君當得勝",
   "丁口": "好音時來，人口平安",
   "生意": "起手艱難，收功大利",
   "疾病": "病勢雖重，可保平安",
   "出行": "客路艱難，必有際遇",
   "失物": "運逢小耗，謹守無害",
   "田畜": "畜牧田財，勤勞得利"
  }
 },
 {
  "id": 84,
  "level": "中",
  "poem": [
   "青蚨盈萬積如坵",
   "收拾無從歎不休",
   "好把一繩穿貫去",
   "教君怕足更何求"
  ],
  "official": {
   "功名": "專心勤學，可保成名",
   "行人": "一帆風順，送到行人",
   "婚姻": "家道興隆，當得內助",
   "官司": "認清道路，可合官情",
   "丁口": "家庭安慶，不必多慮",
   "生意": "財氣滿足，好好收成",
   "疾病": "一心調養，自得安康",
   "出行": "出門有財，祈神保佑",
   "失物": "偶有遺失，指點尋歸",
   "田畜": "生息豐餘，收成富足"
  }
 },
 {
  "id": 85,
  "level": "下下",
  "poem": [
   "命犯孤辰只合休",
   "駌鴦兩下遂溪流",
   "枯楊豈肯重生葉",
   "風雨飄零空自愁"
  ],
  "official": {
   "功名": "一生貧賤，名利皆空",
   "行人": "星稀月落，夢影迷離",
   "婚姻": "既鮮遇合，兼乏財丁",
   "官司": "命運不通，事多荊棘",
   "丁口": "門衰戶冷，孤苦伶仃",
   "生意": "事業飄零，營生愈拙",
   "疾病": "燈盡煙消，水盡山窮",
   "出行": "東走西奔，棲身莫定",
   "失物": "命犯破耗，自有失脫",
   "田畜": "六賊搬運，雞犬不寧"
  }
 },
 {
  "id": 86,
  "level": "下下",
  "poem": [
   "生長江河慣御船",
   "誰知翻覆有多端",
   "青龍若遇當無恙",
   "白虎相冲心膽寒"
  ],
  "official": {
   "功名": "妄想功名，反多驚險",
   "行人": "行途多遲，逢辰可遇",
   "婚姻": "事多反覆，且忌寅生",
   "官司": "步步小心，恐防反覆",
   "丁口": "家門未利，當有小災",
   "生意": "故作誤為，經營不利",
   "疾病": "病體反覆，須當小心",
   "出行": "恃才妄行，心多驚險",
   "失物": "指東話西，得失參半",
   "田畜": "牧養遜前，田畜小利"
  }
 },
 {
  "id": 87,
  "level": "中中",
  "poem": [
   "長舌之言不可聽",
   "謹防世上小人心",
   "汝今問我凶和吉",
   "同氣三人可斷金"
  ],
  "official": {
   "功名": "欲求功名，先修倫常",
   "行人": "同氣相求，行人即到",
   "婚姻": "好謀棠棣，莫問姻緣",
   "官司": "兄弟相和，可禦外侮",
   "丁口": "家門和順，諸事平安",
   "生意": "兄弟同心，黃土變金",
   "疾病": "陰人見咎，早禳為佳",
   "出行": "居家啾唧，出門有慶",
   "失物": "閑言勿聽，同心可尋",
   "田畜": "田宅平平，家和事興"
  }
 },
 {
  "id": 88,
  "level": "上",
  "poem": [
   "有人販得洞庭紅",
   "鉅萬財源頃刻通",
   "男子運來難預料",
   "今朝送汝一帆風"
  ],
  "official": {
   "功名": "祿運亨通，功名得志",
   "行人": "好音自至，頃刻相逢",
   "婚姻": "助夫益子，諸事順利",
   "官司": "貴人相扶，事事勝人",
   "丁口": "家門順利，百事迪吉",
   "生意": "財運亨通，諸事咸宜",
   "疾病": "勿藥有喜，身體康安",
   "出行": "利有攸往，出門大吉",
   "失物": "財旺之時，可免失脫",
   "田畜": "田財興旺，物畜豐餘"
  }
 },
 {
  "id": 89,
  "level": "中",
  "poem": [
   "東舍烹牛禱不靈",
   "不如西舍點青燈",
   "上天感應憑方寸",
   "壹念精誠神鬼欽"
  ],
  "official": {
   "功名": "存心向善，前程有望",
   "行人": "若問音信，行踪未定",
   "婚姻": "且宜隨緣，休生妄想",
   "官司": "錢不可通，須憑理斷",
   "丁口": "好憑方寸，自得平安",
   "生意": "不敢妄求，自然平穩",
   "疾病": "宜緩小刻，可保康安",
   "出行": "大望難成，小就則可",
   "失物": "急向西覓，大財難歸",
   "田畜": "多求則拙，小畜無妨"
  }
 },
 {
  "id": 90,
  "level": "中中",
  "poem": [
   "梓匠輪輿一事專",
   "養家糊口足盤餐",
   "莫生奢望思遷業",
   "惹得風波反不安"
  ],
  "official": {
   "功名": "好求溫飽，莫問前程",
   "行人": "既得旅食，莫便思歸",
   "婚姻": "只宜低就，莫攀高門",
   "官司": "勿思爭執，恐惹風波",
   "丁口": "但能知足，可保平安",
   "生意": "改舊必失，守舊則安",
   "疾病": "信舊醫藥，自能安順",
   "出行": "安份為佳，出門多阻",
   "失物": "失物雖回，餘悔未絕",
   "田畜": "不必多求，平平乃過"
  }
 },
 {
  "id": 91,
  "level": "中中",
  "poem": [
   "分明壹樹牡丹花",
   "正欲開時豔若霞",
   "忽遇狂風頃刻至",
   "摧殘技葉萎泥沙"
  ],
  "official": {
   "功名": "好夢將成，忽然驚醒",
   "行人": "音信要通，無知沉絕",
   "婚姻": "若圖眼前，恐無長久",
   "官司": "要求長勝，反受禍殃",
   "丁口": "好景不長，人丁有損",
   "生意": "鏡花水月，事事皆空",
   "疾病": "烏啼月落，燈燼香消",
   "出行": "關山險阻，烟霧迷茫",
   "失物": "物已消化，不用追求",
   "田畜": "莫誇繁盛，恐有天災"
  }
 },
 {
  "id": 92,
  "level": "中",
  "poem": [
   "萬事無如忍最宜",
   "勸君三覆細尋思",
   "逢人切莫輕唐突",
   "須學留侯進履時"
  ],
  "official": {
   "功名": "謹慎待時，還宜早退",
   "行人": "音信遲遲，何須性急",
   "婚姻": "緩圖可就，急躁難成",
   "官司": "退讓三分，可保無事",
   "丁口": "安祥守己，家和事興",
   "生意": "安心忍耐，自得便宜",
   "疾病": "謹慎調和，切忌生氣",
   "出行": "步步容忍，謙和有益",
   "失物": "得失無常，何須煩腦",
   "田畜": "勿貪小利，徒自勤勞"
  }
 },
 {
  "id": 93,
  "level": "中中",
  "poem": [
   "泰華峯巔覓住家",
   "果然地位迥堪誇",
   "豈知歷盡登臨苦",
   "方占山頭一片霞"
  ],
  "official": {
   "功名": "縱得光輝，彩雲易散",
   "行人": "事多艱阻，音信虛無",
   "婚姻": "事無實際，妻家難靠",
   "官司": "休誇依靠，得少失多",
   "丁口": "不肯自卑，虛花難久",
   "生意": "費盡心機，沾光有限",
   "疾病": "竭力調治，安亦偶然",
   "出行": "跋涉艱難，知音甚少",
   "失物": "費心尋覓，亦難全歸",
   "田畜": "雞黍寥落，其利甚微"
  }
 },
 {
  "id": 94,
  "level": "中下",
  "poem": [
   "昔年漁夫入桃源",
   "雞黍相留笑語喧",
   "今日再來無覓處",
   "皆因福薄與緣慳"
  ],
  "official": {
   "功名": "初年得志，晚運蕭條",
   "行人": "水遠山長，相逢不易",
   "婚姻": "前緣已盡，後會難期",
   "官司": "前順後逆，事多不濟",
   "丁口": "瞻望門閭，事多蕭條",
   "生意": "起手得利，恐少收成",
   "疾病": "小癒當慎，復病難痊",
   "出行": "不須再往，只恐空歸",
   "失物": "已無覓處，何必追尋",
   "田畜": "田園荒落，桑拓蕭條"
  }
 },
 {
  "id": 95,
  "level": "中上",
  "poem": [
   "墻圍竹木稻盈田",
   "雞犬桑麻境境徧",
   "完卻官糧無別事",
   "太平世界一神仙"
  ],
  "official": {
   "功名": "福自天成，一生富貴",
   "行人": "桃源樂境，漁人自來",
   "婚姻": "家室安寧，一生穩足",
   "官司": "天相吉人，官事順遂",
   "丁口": "家門清吉，人口平安",
   "生意": "隨分經營，一生財旺",
   "疾病": "保合太和，身體康泰",
   "出行": "一路平穩，諸事順利",
   "失物": "不出門庭，何愁損失",
   "田畜": "田財進益，六畜豐盛"
  }
 },
 {
  "id": 96,
  "level": "中下",
  "poem": [
   "到處生財人莫知",
   "何須奢望遠求之",
   "壹兩黃金四兩福",
   "無如命運本差池"
  ],
  "official": {
   "功名": "福分有限，到底難成",
   "行人": "阻隔山河，參差難見",
   "婚姻": "逆水行舟，事終有阻",
   "官司": "私不勝理，難免招災",
   "丁口": "門戶冷淡，恐有小災",
   "生意": "費盡心機，空勞無濟",
   "疾病": "病重藥輕，難收功效",
   "出行": "命運不濟，徒勞跋涉",
   "失物": "捨近求遠，終歸難覓",
   "田畜": "氣不旺見，孳息無成"
  }
 },
 {
  "id": 97,
  "level": "中",
  "poem": [
   "目今雖遇颶風狂",
   "雞犬逢時免禍殃",
   "依舊壹天晴色好",
   "教君安穩樂徜徉"
  ],
  "official": {
   "功名": "目前雖阻，後運亨通",
   "行人": "若問行踪，須交酉戌",
   "婚姻": "如逢酉戌，家道興隆",
   "官司": "事多驚險，幸遇青天",
   "丁口": "目下未安，秋冬平順",
   "生意": "目下未利，且待小春",
   "疾病": "先憂後善，終得平安",
   "出行": "雖多險道，終能平安",
   "失物": "小往大來，不必怨悔",
   "田畜": "春夏平常，秋冬獲利"
  }
 },
 {
  "id": 98,
  "level": "上",
  "poem": [
   "榮華富貴爵巍峨",
   "忠孝之人感太和",
   "不遇風波無患難",
   "元亨利貞致福多"
  ],
  "official": {
   "功名": "富貴天生，功名得志",
   "行人": "好音頻來，相逢不遠",
   "婚姻": "夫榮子貴，一世亨通",
   "官司": "吉人天相，諸事稱心",
   "丁口": "迎祥集福，人口平安",
   "生意": "貨物生財，安穩得利",
   "疾病": "不必憂疑，即得痊癒",
   "出行": "一路平安，無往不利",
   "失物": "一生穩足，自無破失",
   "田畜": "田園豐登，六畜俱亨"
  }
 },
 {
  "id": 99,
  "level": "上上",
  "poem": [
   "簷前忽聽鵲聲喧",
   "知有佳音到汝門",
   "官職遷陞行客至",
   "百凡順遂不須論"
  ],
  "official": {
   "功名": "喜音重重，功名顯達",
   "行人": "鵲報好音，行人即至",
   "婚姻": "夫妻和順，財喜臨門",
   "官司": "貴人有緣，諸事順遂",
   "丁口": "家室盈寧，芝蘭茂盛",
   "生意": "經營順利，發財添喜",
   "疾病": "福星拱照，悔吝自清",
   "出行": "出門順利，滿載而歸",
   "失物": "偶有疏忽，尋而復得",
   "田畜": "門閭增喜，物阜財豐"
  }
 },
 {
  "id": 100,
  "level": "上上",
  "poem": [
   "此籤壹百最難逢",
   "氣象巍巍實不同",
   "識得謙冲持滿意",
   "萬人頭上逞英雄"
  ],
  "official": {
   "功名": "履滿思謙，崇高永泰",
   "行人": "坐久忽逢，遂心滿意",
   "婚姻": "白頭偕老，吉祥如意",
   "官司": "能以理勝，自占上風",
   "丁口": "春色盈門，百事如意",
   "生意": "所向得利，加人一籌",
   "疾病": "善能調養，後福無量",
   "出行": "順風揚帆，無往不利",
   "失物": "不必張揚，自可尋獲",
   "田畜": "時泰年豐，百產如意"
  }
 }
]