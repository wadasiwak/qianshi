[
 {
  "id": 21,
  "level": "中",
  "poem": [
   "汝今行運未全通",
   "且看春來萬象融",
   "疾病漸瘳元氣復",
   "自然事事稱心胸"
  ],
  "official": {
   "功名": "名利多阻，運到即通",
   "行人": "若問好音，開春可至",
   "婚姻": "目下未利，且待來春",
   "官司": "是非明白，不必憂慮",
   "丁口": "春色盈門，合家清吉",
   "生意": "目下苦守，新年乃佳",
   "疾病": "疾厄漸消，逢春便吉",
   "出行": "若望東行，終當有慶",
   "失物": "謹慎小心，可無後患",
   "田畜": "今歲未利，開春乃佳"
  }
 },
 {
  "id": 22,
  "level": "下下",
  "poem": [
   "福澤從來未易求",
   "枉勞心力費鑽謀",
   "到頭無益徒貽笑",
   "疾病相侵萬事休"
  ],
  "official": {
   "功名": "枉費心機，求榮反辱",
   "行人": "流落天涯，音信寥落",
   "婚姻": "痴人妄想，到底無成",
   "官司": "命犯官符，當有小災",
   "丁口": "鶴望淒涼，雁聲鳴咽",
   "生意": "勞心費力，謀求無益",
   "疾病": "神靈不祐，醫藥徒然",
   "出行": "背井離鄉，須防失利",
   "失物": "陰人算計，須防失脫",
   "田畜": "禾黍蕭條，羽毛零落"
  }
 },
 {
  "id": 23,
  "level": "中",
  "poem": [
   "行舟共識賴神明",
   "椗舵當教要小心",
   "莫到急流方著力",
   "閒中打點免災侵"
  ],
  "official": {
   "功名": "欲望榮華，須先努力",
   "行人": "會少離多，音書稀少",
   "婚姻": "當圖安穩，莫任攀高",
   "官司": "諸事退讓，方為平穩",
   "丁口": "眷口啾唧，可無大害",
   "生意": "利息微薄，須要把握",
   "疾病": "小心保養，庶可無虞",
   "出行": "步步小心，平安無事",
   "失物": "命犯破財，有小失脫",
   "田畜": "田園荒落，孳息稀疏"
  }
 },
 {
  "id": 24,
  "level": "上中",
  "poem": [
   "共道今年勝舊年",
   "家門氣象覺熙恬",
   "勸君得隴毋望蜀",
   "卻省中懷似火煎"
  ],
  "official": {
   "功名": "得尺得寸，不可躁進",
   "行人": "魚雁相通，可慰懸念",
   "婚姻": "娶妻迪吉，納妾招禍",
   "官司": "事理平穩，適可而止",
   "丁口": "新運勝舊，平安為福",
   "生意": "運氣漸佳，安心能守",
   "疾病": "潮月勿藥，可保痊安",
   "出行": "只宜步穩，不可橫行",
   "失物": "財勿已去，悔之無益",
   "田畜": "景象舒適，當續順遂"
  }
 },
 {
  "id": 25,
  "level": "中",
  "poem": [
   "臘雪消除春水生",
   "沙灘不礙客舟行",
   "載來貨物誇多利",
   "須慮旁人覬覦生"
  ],
  "official": {
   "功名": "前程有望，謹慎為先",
   "行人": "春信已通，行人即到",
   "婚姻": "須早圖謀，遲則有變",
   "官司": "諸事順利，適可而止",
   "丁口": "人口平安，宜防口舌",
   "生意": "財氣頗佳，須防後變",
   "疾病": "疾已痊癒，謹慎保身",
   "出行": "此去慎行，須防小人",
   "失物": "陰人暗算，尚須謹防",
   "田畜": "利息雖好，恐有失脫"
  }
 },
 {
  "id": 26,
  "level": "上中",
  "poem": [
   "旱年宜豆雨宜禾",
   "合著天時總不差",
   "若遇南風應買豆",
   "今年利息十分多"
  ],
  "official": {
   "功名": "命坐文昌，科名有望",
   "行人": "消息已通，午日即到",
   "婚姻": "姻緣可成，丙丁尤利",
   "官司": "占多吉兆，可以無憂",
   "丁口": "人口平安，勝於舊年",
   "生意": "相機而行，可得大利",
   "疾病": "南風解散，災悔消除",
   "出行": "祿馬在午，利有攸往",
   "失物": "物失在南，尋之必獲",
   "田畜": "秋冬平常，入夏大利"
  }
 },
 {
  "id": 27,
  "level": "中",
  "poem": [
   "讀書十載不成名",
   "卻要經營往外行",
   "涉水登山程萬里",
   "報君好事在先庚"
  ],
  "official": {
   "功名": "功名不成，改途得利",
   "行人": "行人在途，逢庚必到",
   "婚姻": "捨近求遠，方可有成",
   "官司": "事和為貴，息訟遠行",
   "丁口": "眷屬平安，秋來更好",
   "生意": "庚辛是金，利得十分",
   "疾病": "消遣為佳，不宜沉悶",
   "出行": "西方大利，必有遇合",
   "失物": "步步小心，須防失脫",
   "田畜": "雞黍得利，且待收成"
  }
 },
 {
  "id": 28,
  "level": "中上",
  "poem": [
   "天生驥足豈尋常",
   "自幼生來骨格強",
   "馳騁康莊無絆礙",
   "一逢伯樂便稱良"
  ],
  "official": {
   "功名": "富貴前定，必遇知音",
   "行人": "行人在途，相逢不遠",
   "婚姻": "幸得知心，所求必遂",
   "官司": "貴人扶助，諸事大吉",
   "丁口": "親有扶持，眷屬安吉",
   "生意": "同心協力，土可變金",
   "疾病": "醫藥有緣，指日可癒",
   "出行": "有志四方，必有際遇",
   "失物": "偶爾疏忽，完壁歸來",
   "田畜": "孳生長養，善價而沽"
  }
 },
 {
  "id": 29,
  "level": "上中",
  "poem": [
   "無論築室與開山",
   "方向通時總一般",
   "若遇貴人來拱照",
   "吉凶趨避在其間"
  ],
  "official": {
   "功名": "安心待時，必有遇合",
   "行人": "音信遲滯，久而復通",
   "婚姻": "吉星高照，定可成家",
   "官司": "恩星拱照，諸事無妨",
   "丁口": "音信頻通，合門安吉",
   "生意": "貨物揀擇，穩當得利",
   "疾病": "病去如絲，須當擇醫",
   "出行": "客路有緣，出門大吉",
   "失物": "謹慎防閑，不致失財",
   "田畜": "六畜興旺，田園得利"
  }
 },
 {
  "id": 30,
  "level": "中下",
  "poem": [
   "大海茫茫未有涯",
   "扁舟飄蕩寔堪嗟",
   "我今指引平安路",
   "路在心頭汝自思"
  ],
  "official": {
   "功名": "功名遲滯，自悔蹉跎",
   "行人": "魚書雁帛，雲水茫茫",
   "婚姻": "且莫強求，終當有遇",
   "官司": "何須成訟，自反為佳",
   "丁口": "家口未利，保泰求安",
   "生意": "利息平常，安穩為佳",
   "疾病": "凶多吉少，祈禱無妨",
   "出行": "客路艱難，家居為貴",
   "失物": "失物已去，消息全無",
   "田畜": "生息稀少，且有小損"
  }
 },
 {
  "id": 31,
  "level": "下下",
  "poem": [
   "神明感格在虔誠",
   "爾未誠心禱豈靈",
   "速向隱微求改悔",
   "免教旦夕禍災生"
  ],
  "official": {
   "功名": "富貴在天，妄想何益",
   "行人": "天空海闊，音信渺茫",
   "婚姻": "事多荊棘，追求無益",
   "官司": "自已不仁，於人何尤",
   "丁口": "家中不和，致有災禍",
   "生意": "急流勇退，免得後悔",
   "疾病": "虔誠祈禱，或保無妨",
   "出行": "恐有後悔，及早歸家",
   "失物": "命該失脫，何須煩惱",
   "田畜": "氣象衰微，羽毛憔悴"
  }
 },
 {
  "id": 32,
  "level": "下下",
  "poem": [
   "雨雪霏霏路不通",
   "人家煙火杳無蹤",
   "算來命運當如此",
   "禱告神明計亦窮"
  ],
  "official": {
   "功名": "窮愁潦倒，一事無成",
   "行人": "海角天涯，難覓消息",
   "婚姻": "空費精神，顛倒錯亂",
   "官司": "相爭相競，吉少凶多",
   "丁口": "伶仃困苦，門戶無聊",
   "生意": "本少利微，恐有失誤",
   "疾病": "命犯龍蛇，醫藥罕效",
   "出行": "風浪危險，辛苦徒然",
   "失物": "小有破財，庶免災悔",
   "田畜": "命運不濟，災悔及物"
  }
 },
 {
  "id": 33,
  "level": "中",
  "poem": [
   "寶物原當密密藏",
   "被人暗損費周章",
   "果然失脫增煩腦",
   "若待尋時在近方"
  ],
  "official": {
   "功名": "聰明自露，犯人所忌",
   "行人": "相遇非遥，恐有失誤",
   "婚姻": "機關不慎，難望有成",
   "官司": "漏洩機關，曲多直少",
   "丁口": "家中有災，可無大礙",
   "生意": "同人暗算，利息微薄",
   "疾病": "尋醫不遠，保養小心",
   "出行": "事多阻障，不必遠行",
   "失物": "自不小心，運當失脫",
   "田畜": "不用多思，經營少利"
  }
 },
 {
  "id": 34,
  "level": "上",
  "poem": [
   "君來未卜我先知",
   "欲向前途問險夷",
   "好待桃花春浪發",
   "龍門一躍是良期"
  ],
  "official": {
   "功名": "官運已通，功名得志",
   "行人": "春風送暖，好音便來",
   "婚姻": "婚姻可成，且待佳麗",
   "官司": "吉人天相，事事稱心",
   "丁口": "春色盈門，長幼咸吉",
   "生意": "處處生財，交春更好",
   "疾病": "宿疾漸瘳，逢春漸癒",
   "出行": "此去得意，衣錦榮歸",
   "失物": "小心防範，百無一失",
   "田畜": "雞黍多利，桑麻倍利"
  }
 },
 {
  "id": 35,
  "level": "上中",
  "poem": [
   "乘雲馭氣一神仙",
   "來到南方結善緣",
   "欲買金舟求不死",
   "須將牛犬戒為先"
  ],
  "official": {
   "功名": "戒食牛犬，自得功名",
   "行人": "薰風南來，遇我知已",
   "婚姻": "丙丁作合，丑戌當忌",
   "官司": "貴人有緣，提拔得力",
   "丁口": "家室平安，當結善緣",
   "生意": "財出南方，必得大利",
   "疾病": "誠心齋戒，祈禱必安",
   "出行": "遵海而南，利有攸往",
   "失物": "小有失脫，須當戒慎",
   "田畜": "入夏以來，頗有生色"
  }
 },
 {
  "id": 36,
  "level": "上中",
  "poem": [
   "逢蛇遇虎多驚恐",
   "須識山行遜水行",
   "借汝一帆風力順",
   "陶朱貨殖有榮名"
  ],
  "official": {
   "功名": "捨北圖南，榮光指日",
   "行人": "順風揚帆，目前可到",
   "婚姻": "如係東南，更增光輝",
   "官司": "貴人抬眼，自有照應",
   "丁口": "家室富有，人口康寧",
   "生意": "去陸就水，利息十分",
   "疾病": "指日痊可，不必驚疑",
   "出行": "出門順利，際會風雲",
   "失物": "失物未遠，當在水濱",
   "田畜": "種竹養魚，獲利加倍"
  }
 },
 {
  "id": 37,
  "level": "中中",
  "poem": [
   "骨肉緣何有異心",
   "自因疾病苦相侵",
   "勸汝改圖行孝弟",
   "挽回造化莫因循"
  ],
  "official": {
   "功名": "欲求榮顯，先篤天倫",
   "行人": "雲樹迷離，望之不見",
   "婚姻": "事情未順，只恐難成",
   "官司": "理屈詞窮，挽回宜急",
   "丁口": "家門不和，致多戾氣",
   "生意": "家門和好，黃土變金",
   "疾病": "自作之孽，祈禱須誠",
   "出行": "學做善人，然後可行",
   "失物": "自不小心，命當破耗",
   "田畜": "田園荒落，六畜蕭條"
  }
 },
 {
  "id": 38,
  "level": "上中",
  "poem": [
   "莫道神明事渺茫",
   "誠心禱告降嘉祥",
   "福緣善慶真無爽",
   "天道昭昭曲直彰"
  ],
  "official": {
   "功名": "欲望功名，須先積德",
   "行人": "旬日之後，當有好音",
   "婚姻": "事當誠求，姻緣有望",
   "官司": "神靈默佑，庶可平安",
   "丁口": "若要家安，須行善事",
   "生意": "輕財樂施，必獲大利",
   "疾病": "祈安保泰，勿藥有喜",
   "出行": "修德行仁，何往不利",
   "失物": "自已疏忽，無悔亡羊",
   "田畜": "念念作德，物物生財"
  }
 },
 {
  "id": 39,
  "level": "中",
  "poem": [
   "我本慈航大士身",
   "扶危救苦濟紅塵",
   "吉凶禍福雖前定",
   "善念一萌神鬼欽"
  ],
  "official": {
   "功名": "大善回天，富貴必得",
   "行人": "音信已通，目前可到",
   "婚姻": "姻緣前定，守正則吉",
   "官司": "急性者凶，敬慎者吉",
   "丁口": "積善之家，必有餘慶",
   "生意": "無愧神明，勤必有利",
   "疾病": "神靈庇佑，勿藥有喜",
   "出行": "步步行仁，避凶趨吉",
   "失物": "小心提防，可無差失",
   "田畜": "生財有道，先看存心"
  }
 },
 {
  "id": 40,
  "level": "下下",
  "poem": [
   "汝今心地不分明",
   "枉向神前禱告頻",
   "富貴榮華無汝分",
   "官非口舌與逡巡"
  ],
  "official": {
   "功名": "妄作誤為，常不飽煖",
   "行人": "霧障雲封，歸心未決",
   "婚姻": "本非可圖，求之無益",
   "官司": "官法如爐，難逃秉鑒",
   "丁口": "乖氣致戾，當有災悔",
   "生意": "妄想得利，反致破財",
   "疾病": "自取之禍，祈禱無益",
   "出行": "落落萍踪，惟悲失路",
   "失物": "逆來順受，報應無差",
   "田畜": "田園將蕪，木凋草枯"
  }
 }
]