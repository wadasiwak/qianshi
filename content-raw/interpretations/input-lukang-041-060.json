[
 {
  "id": 41,
  "level": "上中",
  "poem": [
   "百工執業各須專",
   "自有財源漸漸添",
   "過得殘冬春又至",
   "東風烘暖換新年"
  ],
  "official": {
   "功名": "欲求功名，先須努力",
   "行人": "春信一通，故人可遇",
   "婚姻": "專心誠求，交春有望",
   "官司": "且待開春，自有好音",
   "丁口": "人口粗安，明春更好",
   "生意": "專心致志，日久生財",
   "疾病": "專心醫治，逢春始痊",
   "出行": "順水行舟，春潮相送",
   "失物": "謹守繩尺，可無差失",
   "田畜": "捨舊圖新，倍有生色"
  }
 },
 {
  "id": 42,
  "level": "上",
  "poem": [
   "十分財喜到君家",
   "從此謀為事事嘉",
   "管取一生康且泰",
   "春風看徧上林花"
  ],
  "official": {
   "功名": "福祿天成，功成名就",
   "行人": "燈花報喜，好音頻來",
   "婚姻": "婚姻和合，財喜重重",
   "官司": "吉人天相，凡事平安",
   "丁口": "日日平安，時時吉慶",
   "生意": "財氣穩足，動作如意",
   "疾病": "身躬康泰，消災解厄",
   "出行": "順風揚帆，利有攸往",
   "失物": "財氣不散，去而復來",
   "田畜": "物物豐盛，處處生財"
  }
 },
 {
  "id": 43,
  "level": "中",
  "poem": [
   "夏秋未免多啾唧",
   "冬至方教境遇昌",
   "莫近細人增口舌",
   "好修陰騭卻災殃"
  ],
  "official": {
   "功名": "中年未利，晚景方佳",
   "行人": "雁足傳書，十月可遇",
   "婚姻": "遲則有成，還須謹慎",
   "官司": "存心行已，不必責人",
   "丁口": "夏秋啾唧，冬至平安",
   "生意": "夏秋平平，交冬得利",
   "疾病": "悔過遷善，交冬自癒",
   "出行": "踏雪尋梅，頗有樂境",
   "失物": "破財流年，交冬平善",
   "田畜": "六節未佳，三冬方好"
  }
 },
 {
  "id": 44,
  "level": "下下",
  "poem": [
   "看來黑白要分明",
   "棋子縱橫布滿枰",
   "汝卻不知先一著",
   "枉勞心力總難贏"
  ],
  "official": {
   "功名": "自已蹉跎，功名難就",
   "行人": "水遠山長，知音難遇",
   "婚姻": "幾當先決，緩則無濟",
   "官司": "詞窮理屈，自悔已遲",
   "丁口": "門庭冷落，丁眷多災",
   "生意": "從前失算，圖利空虛",
   "疾病": "自不保身，服藥罔效",
   "出行": "跋涉艱難，徒悲岐路",
   "失物": "命當破財，悔之何益",
   "田畜": "六畜消耗，雞犬不寧"
  }
 },
 {
  "id": 45,
  "level": "上",
  "poem": [
   "官爵巍巍未可量",
   "君恩隆重世無雙",
   "船頭助汝風帆穩",
   "萬里封侯大吉昌"
  ],
  "official": {
   "功名": "祿位功名，未可限量",
   "行人": "正遇順風，行踪即到",
   "婚姻": "得勢得時，攸往盡利",
   "官司": "太陽高照，陰氣俱消",
   "丁口": "家門清吉，人口平安",
   "生意": "財運亨通，左宜右有",
   "疾病": "精神強旺，勿藥有喜",
   "出行": "利涉大川，百事如意",
   "失物": "尋踪覓跡，只在眼前",
   "田畜": "暢茂條達，財氣有餘"
  }
 },
 {
  "id": 46,
  "level": "下下",
  "poem": [
   "孤蹤飄泊等浮萍",
   "欲渡無舟枉問津",
   "若使當年行善事",
   "何須今日叩神明"
  ],
  "official": {
   "功名": "自不潛修，功名無分",
   "行人": "行踪漂泊，音信虛無",
   "婚姻": "途窮孤另，何以為家",
   "官司": "爾不自諒，於人何尤",
   "丁口": "丁眷有災，當行善事",
   "生意": "財氣空虛，不必妄想",
   "疾病": "誠心祈禱，改過自新",
   "出行": "蹈危履險，跼蹐難安",
   "失物": "自不小心，須當破耗",
   "田畜": "命運不齊，諸事破耗"
  }
 },
 {
  "id": 47,
  "level": "中",
  "poem": [
   "同舟共命諺誠然",
   "究竟中分善惡緣",
   "卻看一輪明月上",
   "清光照徹見媸妍"
  ],
  "official": {
   "功名": "善惡果報，得失自知",
   "行人": "清光照人，中旬可遇",
   "婚姻": "妍媸勿論，喜得團圓",
   "官司": "自問曲直，乃見輸贏",
   "丁口": "家口平安，須當作福",
   "生意": "刁惡愈窮，善人是富",
   "疾病": "悔過從善，祈禱為安",
   "出行": "此去平平，為善則佳",
   "失物": "旬月之中，須防失脫",
   "田畜": "利息平常，無甚生息"
  }
 },
 {
  "id": 48,
  "level": "中下",
  "poem": [
   "千方百計總皆空",
   "枉費心機不見功",
   "直待雪消紅日上",
   "另開局面漸亨通"
  ],
  "official": {
   "功名": "時運未通，且宜坐守",
   "行人": "音信遲延，開春即到",
   "婚姻": "此處未諧，另求為吉",
   "官司": "官非口舌，吉少凶多",
   "丁口": "今歲欠寧，交春方穩",
   "生意": "先貧後富，運到得利",
   "疾病": "病勢遷延，開春自癒",
   "出行": "今歲未到，臘盡方佳",
   "失物": "運值破財，必有失脫",
   "田畜": "目下未利，且待春和"
  }
 },
 {
  "id": 49,
  "level": "上",
  "poem": [
   "貴人相見便相親",
   "真覺風光遠過人",
   "無限榮華從此始",
   "青春努力莫辭勤"
  ],
  "official": {
   "功名": "富貴功名，未可限量",
   "行人": "故人千里，相聚目前",
   "婚姻": "良緣會合，家運興隆",
   "官司": "貴人有緣，風光自勝",
   "丁口": "家室清寧，無災無悔",
   "生意": "利有攸往，財運亨通",
   "疾病": "吉星拱照，災厄自消",
   "出行": "處處有緣，出門大利",
   "失物": "謹慎防範，自無差失",
   "田畜": "田園豐盛，物產滋榮"
  }
 },
 {
  "id": 50,
  "level": "上",
  "poem": [
   "神仙事業由前定",
   "行向東來更向南",
   "取坎填離成大業",
   "長生不死是奇男"
  ],
  "official": {
   "功名": "勤學功成，德盛名至",
   "行人": "春風披拂，遇在東南",
   "婚姻": "水火既濟，求無不利",
   "官司": "喜遇貴人，扶持得力",
   "丁口": "家門清吉，長幼咸安",
   "生意": "財氣充足，頗多生色",
   "疾病": "調養元氣，自能長生",
   "出行": "驅車出門，利在東南",
   "失物": "東南尋之，失而復得",
   "田畜": "物產孳生，田園成熟"
  }
 },
 {
  "id": 51,
  "level": "中",
  "poem": [
   "天河清淺不生波",
   "歲歲雙星安穩過",
   "今屆秋期風浪發",
   "恐驚織女起婆娑"
  ],
  "official": {
   "功名": "安穩成名，恐有後變",
   "行人": "若屆秋期，防有驚險",
   "婚姻": "好椿喜事，恐有反覆",
   "官司": "莫道平安，還須把穩",
   "丁口": "童叟平安，陰人有咎",
   "生意": "春夏生財，秋間不利",
   "疾病": "小有驚恐，大限無妨",
   "出行": "出門安穩，秋來小心",
   "失物": "月逢七八，恐防失脫",
   "田畜": "四季平和，秋成小利"
  }
 },
 {
  "id": 52,
  "level": "中",
  "poem": [
   "寶鏡塵埋久未磨",
   "一朝拂拭起光華",
   "本來神物稱奇秘",
   "魑魅潛形洵足誇"
  ],
  "official": {
   "功名": "篤志潛修，久而必發",
   "行人": "契闊經年，相逢八月",
   "婚姻": "從此團圓，永無駁雜",
   "官司": "貴人抬眼，便有風光",
   "丁口": "人口清吉，災禍不生",
   "生意": "貨物認真，終獲大利",
   "疾病": "元氣既復，陰邪盡消",
   "出行": "明珠暗投，逢時則出",
   "失物": "小心防患，陰人自退",
   "田畜": "靜以待時，終久得利"
  }
 },
 {
  "id": 53,
  "level": "中中",
  "poem": [
   "急水灘頭快著篙",
   "艄公把舵更應牢",
   "須教出得風波險",
   "方見舟師手段高"
  ],
  "official": {
   "功名": "吃盡辛苦，方得顯榮",
   "行人": "行人遲滯，方有好音",
   "婚姻": "勞心成就，還要提防",
   "官司": "事多驚疑，挽回須急",
   "丁口": "存心行善，可保安寧",
   "生意": "利覓蠅頭，勞心費力",
   "疾病": "病勢危險，終久得安",
   "出行": "道路艱難，出險就夷",
   "失物": "防存嚴緊，可以無失",
   "田畜": "勞心勞力，不致損傷"
  }
 },
 {
  "id": 54,
  "level": "中",
  "poem": [
   "從前作事總糊塗",
   "此後修為要切磋",
   "若得一心行正道",
   "自然災悔盡消磨"
  ],
  "official": {
   "功名": "天不負人，修為必吉",
   "行人": "相逢知己，切磋琢磨",
   "婚姻": "好事多磨，守正得吉",
   "官司": "正直無私，立身不敗",
   "丁口": "修德行仁，家門吉慶",
   "生意": "小心勤力，自然獲利",
   "疾病": "虔誠作福，災悔消除",
   "出行": "直道而行，無往不利",
   "失物": "從前疏失，今後小心",
   "田畜": "田財未旺，須得人和"
  }
 },
 {
  "id": 55,
  "level": "中",
  "poem": [
   "千倉米粟積如山",
   "分惠飢貧事不難",
   "勸子殷勤培善果",
   "盛衰興廢本循環"
  ],
  "official": {
   "功名": "幸福富貴，尤易修為",
   "行人": "故人千里，攜手相逢",
   "婚姻": "成家立業，主得內助",
   "官司": "得意之時，須留後步",
   "丁口": "飽暖不滛，自然安泰",
   "生意": "交易公平，自然獲利",
   "疾病": "積德保身，消災解厄",
   "出行": "出門順利，宜結良緣",
   "失物": "偶有遺失，不必追求",
   "田畜": "好事多作，庶物繁昌"
  }
 },
 {
  "id": 56,
  "level": "上",
  "poem": [
   "種得藍田璧一雙",
   "鳳凰相感為翱翔",
   "貴人自有非常遇",
   "代代兒孫保吉昌"
  ],
  "official": {
   "功名": "富貴福澤，源遠流長",
   "行人": "好音將至，相遇非遥",
   "婚姻": "宜室宜家，多子多孫",
   "官司": "貴人扶持，事都如意",
   "丁口": "吉人天相，閤門喜慶",
   "生意": "時來運到，勤必如意",
   "疾病": "指日痊癒，且有後福",
   "出行": "利有攸往，遇合非常",
   "失物": "去而復來，失去復得",
   "田畜": "門廳吉慶，大小咸宜"
  }
 },
 {
  "id": 57,
  "level": "中",
  "poem": [
   "生平冷淡知音少",
   "靜養根苗葆素真",
   "共羨一枝黃菊好",
   "秋深籬落自芳芬"
  ],
  "official": {
   "功名": "盡人待天，後福耐久",
   "行人": "雁足傳書，秋期必到",
   "婚姻": "休圖早就，晚節方佳",
   "官司": "自信無慚，有屈必伸",
   "丁口": "家室平安，秋冬更吉",
   "生意": "安心靜守，利息必多",
   "疾病": "保養精神，交秋即癒",
   "出行": "桂菊陽月，一路亨通",
   "失物": "謹慎小心，得免多失",
   "田畜": "春夏平平，秋來大利"
  }
 },
 {
  "id": 58,
  "level": "上",
  "poem": [
   "四月十月風浪平",
   "告君際遇在庚辛",
   "凡事須循天理去",
   "自然家室得康寧"
  ],
  "official": {
   "功名": "安心向善，必獲際遇",
   "行人": "好音重重，遇合不遠",
   "婚姻": "成家安穩，西方際遇",
   "官司": "際遇貴人，自然無浪",
   "丁口": "存心行善，合家平安",
   "生意": "梅陽月吉，得利更多",
   "疾病": "盡心祈禱，自可痊安",
   "出行": "出門平穩，當有際遇",
   "失物": "向西尋覓，定然可遇",
   "田畜": "春秋平平，夏冬景佳"
  }
 },
 {
  "id": 59,
  "level": "中",
  "poem": [
   "不為工賈不為農",
   "黃卷青燈自苦攻",
   "若問終身休咎事",
   "試看龍虎與雲風"
  ],
  "official": {
   "功名": "際會風雲，功名大顯",
   "行人": "若問行踪，寅辰必到",
   "婚姻": "辛苦成家，遇合得意",
   "官司": "福星拱照，所向得利",
   "丁口": "春色盈門，平安為福",
   "生意": "苦心經營，必獲大利",
   "疾病": "終身平善，疾危消除",
   "出行": "遇在寅辰，利有攸往",
   "失物": "運際昌期，自無損失",
   "田畜": "以長以養，孳息豐盈"
  }
 },
 {
  "id": 60,
  "level": "中",
  "poem": [
   "常憑寶劍辟妖邪",
   "十五年來事足誇",
   "此去更宜韜晦好",
   "磽磽易缺理無差"
  ],
  "official": {
   "功名": "利就名成，急流勇退",
   "行人": "音信稀疏，只看望日",
   "婚姻": "事有反覆，且恐損失",
   "官司": "退讓一步，可以無憂",
   "丁口": "家室平平，幸保無事",
   "生意": "一向穩足，速宜保守",
   "疾病": "勞心勞力，須當保養",
   "出行": "只宜安份，不可遠行",
   "失物": "步步小心，須防失脫",
   "田畜": "田財牧養，後不如前"
  }
 }
]