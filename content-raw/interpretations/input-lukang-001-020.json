[
 {
  "id": 1,
  "level": "上",
  "poem": [
   "曉日曈曈萬象融",
   "河清海晏慶年豐",
   "生逢盛世真歡樂",
   "好把心田答化工"
  ],
  "official": {
   "功名": "水到渠成，扶搖直上",
   "行人": "相逢知己，近在眼前",
   "婚姻": "天定良緣，夫榮子貴",
   "官司": "貴人扶持，有理者勝",
   "丁口": "喜信頻來，合家吉慶",
   "生意": "動作有利，一本萬利",
   "疾病": "枯木逢春，欣欣向榮",
   "出行": "順風揚帆，利有攸往",
   "失物": "重尋有獲，只在東南",
   "田畜": "田園多利，生息繁榮"
  }
 },
 {
  "id": 2,
  "level": "中上",
  "poem": [
   "臣報君恩子報親",
   "五倫無愧感神明",
   "一帆順境憑君去",
   "災難消除福祿生"
  ],
  "official": {
   "功名": "臘盡梅開，到時及第",
   "行人": "燈花報喜，好音自來",
   "婚姻": "夫妻和順，合生貴子",
   "官司": "諸事順理，自然亨通",
   "丁口": "平安為福，長幼咸宜",
   "生意": "所求安分，自有大利",
   "疾病": "如魚得水，勿藥有喜",
   "出行": "有志四方，無往不利",
   "失物": "隱而復現，何必擔心",
   "田畜": "生育茂盛，災障消除"
  }
 },
 {
  "id": 3,
  "level": "上上",
  "poem": [
   "前生結下好姻緣",
   "今日相逢赤線牽",
   "多福多男並多壽",
   "閤門喜慶此為先"
  ],
  "official": {
   "功名": "福祿富足，名利兼收",
   "行人": "薰風南來，遇我好友",
   "婚姻": "如係遠方，更多吉利",
   "官司": "貴人有緣，自能得意",
   "丁口": "門庭春暖，眷屬平安",
   "生意": "財臨午運，南方更利",
   "疾病": "日行丙丁，災厄盡釋",
   "出行": "出門有喜，水陸皆順",
   "失物": "去而復來，求之不遠",
   "田畜": "春生夏長，田財豐足"
  }
 },
 {
  "id": 4,
  "level": "上",
  "poem": [
   "喜逢春令雨霑濡",
   "草木萌芽正及時",
   "志士經營皆得意",
   "農夫多黍女多絲"
  ],
  "official": {
   "功名": "福祿亨通，求名及時",
   "行人": "故人千里，遇合一朝",
   "婚姻": "勤儉作家，枝葉茂盛",
   "官司": "貴人恩庇，決勝無疑",
   "丁口": "咸亨是占，家人有慶",
   "生意": "正行財運，動作得利",
   "疾病": "調和元氣，疾厄漸消",
   "出行": "得見大人，所謀必合",
   "失物": "尋覓及時，定可追回",
   "田畜": "雞犬桑麻，熙然自足"
  }
 },
 {
  "id": 5,
  "level": "上",
  "poem": [
   "卻喜東風一夜催",
   "萬花萬卉各爭開",
   "黃金台上逢知已",
   "酌酒看花意氣恢"
  ],
  "official": {
   "功名": "喜遇知音，功名特達",
   "行人": "春風消息，遇合不遠",
   "婚姻": "媒人得力，主獲妻財",
   "官司": "吉人天相，自有好音",
   "丁口": "春色盈門，主人康安",
   "生意": "枯木逢春，萌芽叢開",
   "疾病": "宿疾漸好，逢庚即癒",
   "出行": "走馬看花，春風得意",
   "失物": "所失甚微，不必留意",
   "田畜": "庶類蕃茂，更勝舊年"
  }
 },
 {
  "id": 6,
  "level": "中",
  "poem": [
   "造物由來總好生",
   "君今求我話分明",
   "西風凜冽東風暖",
   "自把存心仔細評"
  ],
  "official": {
   "功名": "若問前途，先求自已",
   "行人": "音信遲滯，且待開春",
   "婚姻": "凜燠靡常，行止自主",
   "官司": "忍耐為佳，爭競何益",
   "丁口": "存心行善，自能安吉",
   "生意": "安份守舊，不必妄想",
   "疾病": "病體多變，調攝無方",
   "出行": "東去方宜，西方失利",
   "失物": "運當小耗，須防失脫",
   "田畜": "小限落空，孳息小利"
  }
 },
 {
  "id": 7,
  "level": "中下",
  "poem": [
   "滿目風雲咫尺迷",
   "胡為惘惘欲何之",
   "不如急把船頭轉",
   "省得狂波破膽時"
  ],
  "official": {
   "功名": "人不知命，求榮反辱",
   "行人": "思君不見，天各一方",
   "婚姻": "到底不佳，還宜別就",
   "官司": "兩虎相門，必有一傷",
   "丁口": "眷屬有憂，不如歸去",
   "生意": "時運未通，營求無益",
   "疾病": "及早祈禱，危而得安",
   "出行": "風波險窄，無處渡河",
   "失物": "運當失財，庶免餘悔",
   "田畜": "生息稀少，切莫貪心"
  }
 },
 {
  "id": 8,
  "level": "上上",
  "poem": [
   "積德如君歲十年",
   "何須禮拜問神仙",
   "一帆順境誰能及",
   "利有攸往涉大川"
  ],
  "official": {
   "功名": "為善必昌，功德無量",
   "行人": "知心相遇，期在旦夕",
   "婚姻": "夫妻和順，家室興隆",
   "官司": "官星輔助，諸事順利",
   "丁口": "家門清泰，人口平安",
   "生意": "十分財氣，滿載而歸",
   "疾病": "福星拱照，災悔全消",
   "出行": "出門大利，永無阻礙",
   "失物": "失物不遠，只在溪邊",
   "田畜": "田園獲利，孳息繁昌"
  }
 },
 {
  "id": 9,
  "level": "中",
  "poem": [
   "世事怎能獲萬全",
   "總憑一點好心田",
   "吉凶禍福惟人召",
   "我本無私亦不偏"
  ],
  "official": {
   "功名": "廣行陰騭，自行格天",
   "行人": "音信迢遥，尚多阻隔",
   "婚姻": "先憂後喜，守正則吉",
   "官司": "事多失意，退讓為高",
   "丁口": "勸君行善，庶保平安",
   "生意": "存心忠厚，必獲利益",
   "疾病": "保身之法，及早修為",
   "出行": "安份守已，盡人待天",
   "失物": "既往不究，且防後悔",
   "田畜": "盈歉無定，生息平平"
  }
 },
 {
  "id": 10,
  "level": "下下",
  "poem": [
   "泰極否來汝不知",
   "循環往復道無私",
   "回思昔日風光好",
   "卻悔今朝禱告遲"
  ],
  "official": {
   "功名": "盛極當衰，不須奢望",
   "行人": "月缺雲遮，望之不見",
   "婚姻": "只宜安份，不必強求",
   "官司": "官鬼相剋，事多反側",
   "丁口": "門衰戶冷，影隻行單",
   "生意": "草枯花謝，秋景蕭疏",
   "疾病": "自絕於天，祈禱無益",
   "出行": "世路崎嶇，徒勞跋涉",
   "失物": "悖入悖出，報應不差",
   "田畜": "雞犬蕭條，桑麻零落"
  }
 },
 {
  "id": 11,
  "level": "中下",
  "poem": [
   "驚風駭浪失西東",
   "一盞神燈照碧空",
   "急向前途求解脫",
   "上天憫惻是愚蒙"
  ],
  "official": {
   "功名": "欲望榮華，須常修德",
   "行人": "雁落魚沉，相思不見",
   "婚姻": "既多凶險，且有反覆",
   "官司": "多言多敗，多事多悔",
   "丁口": "大小欠安，當祈神佑",
   "生意": "公平交易，庶保安穩",
   "疾病": "誠心祈禱，庶保安寧",
   "出行": "風波四起，及早回頭",
   "失物": "亡羊補牢，尚可得半",
   "田畜": "須防失利，難免災侵"
  }
 },
 {
  "id": 12,
  "level": "中中",
  "poem": [
   "汝曹逐末泛重洋",
   "順意遊行自主張",
   "得利須知尋退步",
   "免教失足悔難當"
  ],
  "official": {
   "功名": "成功者退，勿戀榮華",
   "行人": "風流雲散，會少離多",
   "婚姻": "切莫高攀，須當量力",
   "官司": "得半則吉，求多者殃",
   "丁口": "君子務本，先貴親親",
   "生意": "好風得利，早理歸帆",
   "疾病": "看破一切，謹慎保身",
   "出行": "捨近圖遠，必有後悔",
   "失物": "若欲求全，反更有失",
   "田畜": "小則可望，多則有失"
  }
 },
 {
  "id": 13,
  "level": "上",
  "poem": [
   "天生富貴洵堪誇",
   "畢竟相承積善家",
   "告汝要言無別事",
   "再能培植慶無涯"
  ],
  "official": {
   "功名": "作善降祥，報施不爽",
   "行人": "庭前鵲噪，必有好音",
   "婚姻": "吉人天相，宜爾室家",
   "官司": "神靈庇祐，官貴提攜",
   "丁口": "室家安樂，人口平安",
   "生意": "財運亨通，愈宜修德",
   "疾病": "逢凶化吉，醫禱皆應",
   "出行": "近悦遠來，無往不利",
   "失物": "小往大來，不須介意",
   "田畜": "田禾富足，庶類咸亨"
  }
 },
 {
  "id": 14,
  "level": "上中",
  "poem": [
   "十載窗下苦操修",
   "今日彈冠事壯遊",
   "萬里長風欣得意",
   "直登彼岸不須愁"
  ],
  "official": {
   "功名": "學優登仕，致君澤民",
   "行人": "故人相逢，怡然自得",
   "婚姻": "配合若遲，自然得意",
   "官司": "情詞順理，貴人有緣",
   "丁口": "家人有慶，諸事皆宜",
   "生意": "貿易得利，風水平穩",
   "疾病": "吉星高照，災禍不生",
   "出行": "順風得利，動無不利",
   "失物": "遠處尋覓，當有著落",
   "田畜": "孳息豐盈，十分有利"
  }
 },
 {
  "id": 15,
  "level": "中中",
  "poem": [
   "種稻高原逢旱歲",
   "插苗低畝遇雨年",
   "欲晴不晴雨不雨",
   "天不絕人人絕天"
  ],
  "official": {
   "功名": "痴心妄想，一事無成",
   "行人": "山外青山，煙雲縹渺",
   "婚姻": "所望難成，成亦無濟",
   "官司": "事多反覆，終至憂疑",
   "丁口": "雲散風流，猿啼月落",
   "生意": "生意索然，意興蕭條",
   "疾病": "旱井枯魚，油燼燈暗",
   "出行": "跋涉徒勞，一無所就",
   "失物": "運當破耗，陰人算計",
   "田畜": "籬落蕭條，毫無生趣"
  }
 },
 {
  "id": 16,
  "level": "上中",
  "poem": [
   "君看靈旗忽轉東",
   "定知好事與從容",
   "神天庇祐須思報",
   "一炷心香帝座通"
  ],
  "official": {
   "功名": "文有進益，錄運亨通",
   "行人": "紫氣東來，幸遇故人",
   "婚姻": "有求必成，諸事如意",
   "官司": "貴人扶持，轉禍為福",
   "丁口": "家室豐盈，椿萱並茂",
   "生意": "財行震方，利息加倍",
   "疾病": "幸逢神庇，宿疾漸癒",
   "出行": "順水行舟，東風徐來",
   "失物": "難中不遇，餘物清吉",
   "田畜": "雞犬平穩，禾黍順意"
  }
 },
 {
  "id": 17,
  "level": "中中",
  "poem": [
   "求名從此是亨衢",
   "求利剛逢是利區",
   "但許一心求一事",
   "不容兩念並馳驅"
  ],
  "official": {
   "功名": "所欲必遂，不可過奢",
   "行人": "久旱得霖，相逢有日",
   "婚姻": "見可就成，不須多慮",
   "官司": "但能小勝，不合多求",
   "丁口": "家書一紙，真抵萬金",
   "生意": "喜逢財運，得意便休",
   "疾病": "專心醫治，自可霍然",
   "出行": "風雲際會，必有遇合",
   "失物": "蹤跡未遇，猶可得半",
   "田畜": "六畜平安，利可五分"
  }
 },
 {
  "id": 18,
  "level": "中上",
  "poem": [
   "汝是懸崖一樹梅",
   "一塵不染向春開",
   "待看綠葉成蔭後",
   "結子滿枝調鼎來"
  ],
  "official": {
   "功名": "功名得時，更有後福",
   "行人": "春信吹來，會合不遠",
   "婚姻": "勿嫌清淡，可卜繁昌",
   "官司": "立身不敗，逢凶化吉",
   "丁口": "門楣有喜，桂馥蘭馨",
   "生意": "財源滾滾，積厚流光",
   "疾病": "枯木逢春，自能生發",
   "出行": "出門順利，收成更好",
   "失物": "謹慎把守，失小得多",
   "田畜": "春生秋實，利息盈餘"
  }
 },
 {
  "id": 19,
  "level": "上中",
  "poem": [
   "渭川白頭一漁翁",
   "遇合來時便不同",
   "莫道迍邅心便冷",
   "須將忍耐付窮通"
  ],
  "official": {
   "功名": "大器晚成，老當益壯",
   "行人": "知已相逢，期在歲暮",
   "婚姻": "求媒費力，終當有成",
   "官司": "諸事忍耐，不可便宜",
   "丁口": "衣錦榮歸，團圓喜慶",
   "生意": "晚運亨通，只宜堅忍",
   "疾病": "耐煩保身，逢春即癒",
   "出行": "守志自力，必有際遇",
   "失物": "運犯小耗，更當謹守",
   "田畜": "春夏小利，秋冬乃成"
  }
 },
 {
  "id": 20,
  "level": "上中",
  "poem": [
   "制虎降龍靜煉丹",
   "從今縱躍出玄關",
   "前途一片風光好",
   "不到蓬萊只等閑"
  ],
  "official": {
   "功名": "苦而得甘，不負所志",
   "行人": "音信艱難，萍踪寡合",
   "婚姻": "逢寅遇辰，成家最利",
   "官司": "是非可免，從此亨通",
   "丁口": "若門家丁，從此安康",
   "生意": "欲求利益，利得十分",
   "疾病": "所得宿疾，從此痊癒",
   "出行": "出門遇合，西行較勝",
   "失物": "財物已去，何必追尋",
   "田畜": "田財利息，當勝舊年"
  }
 }
]